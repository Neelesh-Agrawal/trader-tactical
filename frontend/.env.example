# =============================================================================
# FRONTEND — copy this file to `frontend/.env`
# =============================================================================

# Backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Must match backend APP_MODE for consistent auth:
#   DEV  = skip login, dummy user injected (quick UI testing)
#   PROD = require login + JWT (full registration/login flow)
VITE_APP_MODE=PROD

# =============================================================================
# BACKEND ENVIRONMENT — copy to project root as `.env`
# =============================================================================

# SECURITY
SECRET_KEY=your-django-secret-key-here
DEBUG=True
APP_MODE=PROD
SECURE_SSL_REDIRECT=False

# Domain (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://your-domain.com,https://www.your-domain.com

# Database — use sqlite for quick local dev, or mysql for production parity
DB_ENGINE=mysql
DB_NAME=lms_db
DB_USER=django
DB_PASSWORD=djangopass
DB_HOST=localhost
DB_PORT=3306

# Email (GoDaddy example)
EMAIL_HOST=smtpout.secureserver.net
EMAIL_PORT=465
EMAIL_USE_TLS=false
EMAIL_USE_SSL=true
EMAIL_HOST_USER=donotreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=donotreply@yourdomain.com

# SMS OTP — Moplet (trader-tactical default)
# MOPLET_API_KEY=your-moplet-api-key
# MOPLET_SENDER_ID=MOPLET

# SMS OTP — Fortius (Hostinger production, used when Moplet is not set)
SMS_API_URL=https://smsfortius.org/V2/
SMS_API_KEY=your-fortius-api-key
SMS_SENDER_ID=YOUR_SENDER
SMS_OTP_TEMPLATE_ID=your-dlt-template-id
# Leave blank to use TradeMaster OTP text from trader-tactical repo
# SMS_OTP_MESSAGE_TEMPLATE=Your TradeMaster verification code is: {otp}. This code expires in 5 minutes.
